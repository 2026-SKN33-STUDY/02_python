    "import random\n",
    "\n",
    "menus = ('김밥', '떡볶이', '라면', '우동')\n",
    "def recommend_menu(*menus):\n",
    "    for menu in menus:\n",
    "        print(f'오늘의 점심 메뉴는 {menus} 입니다!')\n",
    "recommend_menu(random.choice(menus))"
   ],
